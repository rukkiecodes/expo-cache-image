    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "expo",
    "react-native",
    "image",
    "cache",
    "cached-image",
    "offline",
    "expo-file-system",
    "prefetch",
    "image-cache"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rukkiecodes/expo-cache-image.git"
  },
  "homepage": "https://github.com/rukkiecodes/expo-cache-image#readme",
  "bugs": {
    "url": "https://github.com/rukkiecodes/expo-cache-image/issues"
  },
  "peerDependencies": {
    "expo-file-system": "*",
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@types/react": "~18.2.0",
    "react": "18.2.0",
    "react-native": "0.74.0",
    "typescript": "^5.4.0"
  }
}
